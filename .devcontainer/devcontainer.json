{
	"name": "Debian",
	"image": "mcr.microsoft.com/devcontainers/base:debian",  // Debian latest

	"features": {
		"ghcr.io/devcontainers/features/sshd:1": { // Used for remote codespaces to support 'gh codespace ssh'. TODO: make this codespaces only
			"version": "latest"
		},
	},
	"postCreateCommand": "bash -c \"$(curl -fsLS https://raw.githubusercontent.com/mbhutton/dotfiles/refs/heads/dev/install-for-linux.sh)\" | tee \"$HOME/install-dev-environment.log\"",
}
